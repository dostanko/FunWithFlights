# Copy this file to .env for local development:
#   cp .env.example .env
#
# In AWS ECS these variables are set on the task definition
# (ECS Console → Task definition → Container → Environment variables),
# NOT through this file.

# ─── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# ─── Providers ──────────────────────────────────────────────────────
# Comma-separated list of provider names. Adding a new provider = add
# its name here + add PROVIDER_<NAME>_URL below. No code changes.
PROVIDERS=provider1,provider2

PROVIDER_PROVIDER1_URL=https://4r5rvu2fcydfzr5gymlhcsnfem0lyxoe.lambda-url.eu-central-1.on.aws/provider/flights1
PROVIDER_PROVIDER2_URL=https://4r5rvu2fcydfzr5gymlhcsnfem0lyxoe.lambda-url.eu-central-1.on.aws/provider/flights2

# ─── HTTP client ────────────────────────────────────────────────────
# Upstream request timeout in milliseconds. On AWS ECS → Lambda URL,
# Lambda cold start can take 3–8 s; bump this if you see initial 504s.
HTTP_TIMEOUT_MS=15000

# Fire one fetch per provider on startup so upstream Lambdas are warm by
# the time real traffic arrives. Default true. Set to `false` to skip
# (e.g. when running offline or in isolated tests).
PROVIDERS_WARMUP=true
