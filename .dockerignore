# Keep the build context lean — fewer files sent to the Docker daemon =
# faster builds and smaller layer surface.

# Dependencies — rebuilt inside the image via `npm ci`.
node_modules

# Build output — rebuilt inside the image via `npm run build`.
dist

# Local env + secrets — MUST NEVER be baked into the image.
.env
.env.*
!.env.example

# Tests — not needed at runtime.
test
**/*.spec.ts
**/*.test.ts
coverage
.nyc_output

# Tooling / editor / VCS artifacts.
.git
.gitignore
.github
.vscode
.idea
.DS_Store
*.log
npm-debug.log*

# Docs — not needed at runtime.
README.md
AGENTS.md
docs

# Local infra helpers (shouldn't be inside the image).
scripts
Dockerfile
.dockerignore
